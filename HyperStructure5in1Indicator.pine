// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//
//  HYPERSTRUCTURE  ·  5-IN-1 INDICATOR
//  A clean, minimal, modular suite — features added one at a time.
//  Every module is toggleable; every input has a recommended ("BEST") value.
//
//  Modules:
//    1 · Round Number Levels      (active)
//    2 · Moving Averages (EMA)    (active)
//    4 · DBox (period range)      (active)
//    5 · News Danger Zones        (active)
//    6 · MTF Trend Dashboard      (active)
//  (Validation Candles and Projection removed.)
//
//@version=6
indicator("HyperStructure5in1Indicator", shorttitle = "HS 5in1", overlay = true,
     max_lines_count = 500, max_labels_count = 500, max_boxes_count = 100)

// ============================================================================
//  GLOBAL DISPLAY
// ============================================================================
var GD = "Display"
txtSize = input.string("Small", "Text size (labels)", options = ["Tiny", "Small", "Normal", "Large"], group = GD,
     tooltip = "Size of module labels. Tiny / Small save chart space.")
f_size() =>
    switch txtSize
        "Tiny"   => size.tiny
        "Normal" => size.normal
        "Large"  => size.large
        => size.small
tSize = f_size()

// ============================================================================
//  MODULE 1 · ROUND NUMBER LEVELS
//  Horizontal grid at every round price level. Minor lines on the base grid,
//  bolder "major" lines every Nth level. Forex (auto pip) + gold / indices /
//  crypto (Price mode).
// ============================================================================
var G1 = "1 · Round Numbers"
rnShow   = input.bool(true, "Show round numbers", group = G1)
rnMode   = input.string("Pips", "Spacing mode", options = ["Pips", "Price"], group = G1,
     tooltip = "PIPS: spacing is in pips (forex). PRICE: spacing is a raw price distance — use this for GOLD / indices / crypto.")
rnSpacing= input.float(50, "Spacing", minval = 0.0001, group = G1,
     tooltip = "Distance between minor levels.\n• Forex (Pips): 500 = 50-pip grid (1.3000, 1.3050). 1000 = 100-pip (1.3000, 1.3100).\n• GOLD (Price): 5 or 10 -> 2000, 2010 ...\n• Indices (Price): 50 or 100.")
rnManPip = input.float(0.0, "Manual pip (Pips mode, 0 = auto)", minval = 0, group = G1,
     tooltip = "Only used in Pips mode. 0 = auto (forex 0.0001, JPY 0.01). Leave at 0 for normal forex.")
rnAuto   = input.bool(true, "Auto-fit gold / indices / crypto", group = G1,
     tooltip = "ON: on non-forex symbols (gold, silver, indices, crypto) the round step is picked AUTOMATICALLY (e.g. gold = $50, US30 = 500) so the lines are sensible without you changing anything. Forex keeps your pip Spacing.")
rnSide   = input.int(14, "Levels each side of price", minval = 1, maxval = 240, group = G1,
     tooltip = "Lines above and below price. BEST 10-16 — keeps the grid clean.")
rnMajorN = input.int(2, "Major every N levels", minval = 0, group = G1,
     tooltip = "Every Nth line is bolder. BEST 2 -> with 500 spacing the 1000 levels stand out. 0 = all identical.")
rnMinCol = input.color(color.new(#2962ff, 60), "Minor", inline = "rmn", group = G1)
rnMinWid = input.int(1, "w", minval = 1, maxval = 4, inline = "rmn", group = G1)
rnMinSty = input.string("Dashed", "", options = ["Solid", "Dashed", "Dotted"], inline = "rmn", group = G1)
rnMajCol = input.color(color.new(#2962ff, 60), "Major", inline = "rmj", group = G1)
rnMajWid = input.int(2, "w", minval = 1, maxval = 5, inline = "rmj", group = G1)
rnMajSty = input.string("Solid", "", options = ["Solid", "Dashed", "Dotted"], inline = "rmj", group = G1)
rnLabMode= input.string("Major", "Labels", options = ["None", "Major", "All"], group = G1,
     tooltip = "BEST 'Major' — clean: only the big round numbers are labelled. 'All' can get busy.")
rnLabSize= input.string("Small", "Label size", options = ["Tiny", "Small", "Normal"], group = G1)
rnLabOff = input.int(25, "Label offset (bars)", minval = 0, maxval = 40, group = G1)

f_lstyle(s) => s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed
f_lsize(s)  => s == "Tiny" ? size.tiny : s == "Normal" ? size.normal : size.small

// --- instrument detection (shared by Round Numbers + DBox) ---
symU     = str.upper(syminfo.ticker)
isJPY    = str.contains(str.upper(syminfo.currency), "JPY") or str.contains(symU, "JPY")
isGold   = str.contains(symU, "XAU") or str.contains(symU, "GOLD")
isSilver = str.contains(symU, "XAG") or str.contains(symU, "SILVER")
isFx     = syminfo.type == "forex"
// smart pip: real pips for forex, $0.10 gold, $0.01 silver, else mintick (= points)
autoPip  = isGold ? 0.1 : isSilver ? 0.01 : isFx ? (isJPY ? 0.01 : 0.0001) : syminfo.mintick

// round-number step: forex uses the pip Spacing; non-forex auto-fits to a clean
// price step (gold $50, silver $1, indices/crypto scaled by price) so they "just work".
rnPip      = rnManPip > 0 ? rnManPip : autoPip
manualStep = rnMode == "Price" ? rnSpacing : rnSpacing * rnPip
autoStep   = isGold ? 50.0 : isSilver ? 1.0 : close >= 50000 ? 1000.0 : close >= 10000 ? 500.0 : close >= 1000 ? 100.0 : close >= 100 ? 10.0 : manualStep
rnStep     = (rnAuto and not isFx) ? autoStep : manualStep   // price distance between minor levels

var line[]  rnLines = array.new<line>()
var label[] rnLabs  = array.new<label>()
if barstate.islast and rnShow and rnStep > 0
    if array.size(rnLines) > 0
        for i = 0 to array.size(rnLines) - 1
            line.delete(array.get(rnLines, i))
        array.clear(rnLines)
    if array.size(rnLabs) > 0
        for i = 0 to array.size(rnLabs) - 1
            label.delete(array.get(rnLabs, i))
        array.clear(rnLabs)
    rnBase = math.round(close / rnStep) * rnStep                 // nearest exact round level
    for k = -rnSide to rnSide
        lvl = rnBase + k * rnStep
        if lvl > 0
            idx   = math.round(lvl / rnStep)
            major = rnMajorN > 0 and idx % rnMajorN == 0
            array.push(rnLines, line.new(bar_index - 1, lvl, bar_index, lvl, xloc = xloc.bar_index,
                 extend = extend.both,
                 color = major ? rnMajCol : rnMinCol,
                 width = major ? rnMajWid : rnMinWid,
                 style = f_lstyle(major ? rnMajSty : rnMinSty)))
            showLab = rnLabMode == "All" or (rnLabMode == "Major" and major)
            if showLab
                array.push(rnLabs, label.new(bar_index + rnLabOff, lvl, str.tostring(lvl, format.mintick),
                     xloc = xloc.bar_index, style = label.style_label_left,
                     color = color.new(color.black, 100), textcolor = major ? rnMajCol : rnMinCol,
                     size = f_lsize(rnLabSize)))

// ============================================================================
//  MODULE 2 · MOVING AVERAGES  (EMA suite — 12 selectable types incl. low-lag)
//  Concept: a moving average is the market's mean price over the last N bars.
//  EMA reacts faster than SMA and, being the most-watched, tends to act as real
//  dynamic support/resistance. Low-lag types (HMA/ZLEMA/DEMA/TEMA/ALMA) react
//  sooner — at the cost of more whipsaw. Volume-weighted types weight by activity.
//  Up to 3 MAs (default 21 / 50 / 200 = the classic 2H/4H swing stack).
// ============================================================================
var G2 = "2 · Moving Averages"
emaOn   = input.bool(true, "Enable Moving Averages", group = G2,
     tooltip = "Single master switch for this whole module.")
maType  = input.string("HMA", "MA type",
     options = ["EMA","SMA","WMA","RMA","VWMA","HMA","ZLEMA","DEMA","TEMA","ALMA","VWZL","VHMA"], group = G2,
     tooltip = "EMA: exponential, market-watched -> real dynamic S/R (BEST for swing).\nSMA: simple, smoothest/slowest.\nWMA: weighted, faster than SMA.\nRMA: Wilder's, very smooth.\nHMA: Hull, low lag + smooth (BEST low-lag).\nZLEMA / DEMA / TEMA: lag-reduced EMAs (fast, more whippy).\nALMA: Gaussian — tune offset/sigma.\nVWMA / VWZL / VHMA: volume-weighted (need REAL volume: futures, indices, gold, crypto).")
maSrc   = input.source(close, "Source", group = G2, tooltip = "Price the MA is built from. BEST close.")
maStyle = input.string("Line", "Line style", options = ["Line","Stepline","Circles"], group = G2)
maLabel = input.bool(true, "Value labels", group = G2)
almaOff = input.float(0.85, "ALMA offset", minval = 0, maxval = 1, step = 0.05, group = G2,
     tooltip = "ALMA only. 0.85 = responsive, lower = smoother.")
almaSig = input.float(6.0,  "ALMA sigma", minval = 1, group = G2, tooltip = "ALMA only. 6 standard.")
// Each MA: toggle | length | width | color
maShow1 = input.bool(true,  "MA1", inline = "ma1", group = G2)
maLen1  = input.int(50,  "", inline = "ma1", group = G2, minval = 1, tooltip = "BEST 21 = fast swing trigger.")
maWid1  = input.int(1, "w", inline = "ma1", group = G2, minval = 1, maxval = 5)
maCol1  = input.color(#089981, "", inline = "ma1", group = G2)
maShow2 = input.bool(true,  "MA2", inline = "ma2", group = G2)
maLen2  = input.int(200,  "", inline = "ma2", group = G2, minval = 1, tooltip = "BEST 50 = swing trend, key institutional level.")
maWid2  = input.int(1, "w", inline = "ma2", group = G2, minval = 1, maxval = 5)
maCol2  = input.color(#e91e63, "", inline = "ma2", group = G2)
maShow3 = input.bool(true,  "MA3", inline = "ma3", group = G2)
maLen3  = input.int(21, "", inline = "ma3", group = G2, minval = 1, tooltip = "BEST 200 = macro trend filter; trade with its slope.")
maWid3  = input.int(1, "w", inline = "ma3", group = G2, minval = 1, maxval = 5)
maCol3  = input.color(#ff9800, "", inline = "ma3", group = G2)
maFill  = input.bool(true, "Fill MA1/MA2", inline = "maf", group = G2)
maFUp   = input.color(color.new(color.green, 80), "", inline = "maf", group = G2)
maFDn   = input.color(color.new(color.red, 80),   "", inline = "maf", group = G2)

// --- low-lag helpers ---
f_zlema(s, l) =>
    lag = math.floor((l - 1) / 2)
    ta.ema(s + (s - s[lag]), l)
f_dema(s, l) =>
    e1 = ta.ema(s, l)
    2 * e1 - ta.ema(e1, l)
f_tema(s, l) =>
    e1 = ta.ema(s, l)
    e2 = ta.ema(e1, l)
    e3 = ta.ema(e2, l)
    3 * (e1 - e2) + e3
f_vzl(s, l) =>
    lag = math.floor((l - 1) / 2)
    ta.vwma(s + (s - s[lag]), l)
f_vhma(s, l) =>
    half = math.max(1, math.round(l / 2.0))
    sq   = math.max(1, math.round(math.sqrt(l)))
    ta.wma(2 * ta.vwma(s, half) - ta.vwma(s, l), sq)
f_ma(s, l, t) =>
    switch t
        "SMA"   => ta.sma(s, l)
        "WMA"   => ta.wma(s, l)
        "RMA"   => ta.rma(s, l)
        "HMA"   => ta.hma(s, l)
        "VWMA"  => ta.vwma(s, l)
        "ZLEMA" => f_zlema(s, l)
        "DEMA"  => f_dema(s, l)
        "TEMA"  => f_tema(s, l)
        "ALMA"  => ta.alma(s, l, almaOff, almaSig)
        "VWZL"  => f_vzl(s, l)
        "VHMA"  => f_vhma(s, l)
        => ta.ema(s, l)
f_pstyle(x) => x == "Stepline" ? plot.style_stepline : x == "Circles" ? plot.style_circles : plot.style_line

ma1 = f_ma(maSrc, maLen1, maType)
ma2 = f_ma(maSrc, maLen2, maType)
ma3 = f_ma(maSrc, maLen3, maType)
plotMa1 = plot(emaOn and maShow1 ? ma1 : na, "MA1", color = maCol1, linewidth = maWid1, style = f_pstyle(maStyle))
plotMa2 = plot(emaOn and maShow2 ? ma2 : na, "MA2", color = maCol2, linewidth = maWid2, style = f_pstyle(maStyle))
plot(emaOn and maShow3 ? ma3 : na, "MA3", color = maCol3, linewidth = maWid3, style = f_pstyle(maStyle))
fill(plotMa1, plotMa2, color = (not emaOn or not maFill or not maShow1 or not maShow2) ? na : (ma1 >= ma2 ? maFUp : maFDn), title = "MA Fill")

var label[] maTags = array.new<label>()
f_maTag(sh, v, c, nm) =>
    if sh
        array.push(maTags, label.new(bar_index + 3, v, nm + " " + str.tostring(v, format.mintick), xloc = xloc.bar_index,
             style = label.style_label_left, color = color.new(c, 15), textcolor = color.white, size = f_lsize(rnLabSize)))
if barstate.islast and emaOn and maLabel
    if array.size(maTags) > 0
        for i = 0 to array.size(maTags) - 1
            label.delete(array.get(maTags, i))
        array.clear(maTags)
    f_maTag(maShow1, ma1, maCol1, maType + str.tostring(maLen1))
    f_maTag(maShow2, ma2, maCol2, maType + str.tostring(maLen2))
    f_maTag(maShow3, ma3, maCol3, maType + str.tostring(maLen3))

// ============================================================================
//  MODULE 4 · DBox  (period range box)
//  Boxes the FULL high-low range of each Day / Week / Month — the whole distance
//  price travelled in that period — anchored to a chosen timezone (IST default).
//  Each box: low->high range, filled bull/bear by the period's open vs close,
//  with an optional period-start vertical line and high/low lines + labels.
//  Engine runs on closed bars only (clean, no intrabar duplicates).
// ============================================================================
var G4 = "4 · DBox (range)"
dboxOn = input.bool(true, "Enable DBox", group = G4,
     tooltip = "Single master switch. Boxes the full high-low range of each Day / Week / Month.")
dbTf   = input.string("Auto", "Time frame", options = ["Auto", "Daily", "Weekly", "Monthly"], group = G4,
     tooltip = "AUTO (default): follows your chart TF — 15m → Daily range, 1H–2H → Weekly, 4H & higher → Monthly. Or force a fixed period.")
dbTz   = input.string("Asia/Kolkata", "Timezone (period anchor)", group = G4,
     tooltip = "Periods start at THIS timezone's midnight / week / month. Default IST (Asia/Kolkata). e.g. 'America/New_York', 'UTC'.")
dbMax  = input.int(16, "History (periods)", minval = 1, maxval = 60, group = G4,
     tooltip = "How many past boxes to keep on the chart. BEST 4-8.")
dbVL   = input.bool(true, "Show vertical line", group = G4)
dbBox  = input.bool(true, "Show box", group = G4)
dbLineCol  = input.color(color.new(color.gray, 0),    "Line color", group = G4)
dbFillBull = input.color(color.new(color.green, 85),  "Fill bull color", group = G4)
dbFillBear = input.color(color.new(color.red, 85),    "Fill bear color", group = G4)

// auto-select the period from the chart timeframe (or use the forced choice)
// 15m & below -> Daily,  1H–2H -> Weekly,  4H & above -> Monthly
autoTf  = timeframe.in_seconds() <= 900 ? "Daily" : timeframe.in_seconds() <= 7200 ? "Weekly" : "Monthly"
dbTfEff = dbTf == "Auto" ? autoTf : dbTf

// period id in the chosen timezone -> changes on each new Day / Week / Month
dbY  = year(time, dbTz)
dbMo = month(time, dbTz)
dbD  = dayofmonth(time, dbTz)
dbW  = weekofyear(time, dbTz)
dbId = dbTfEff == "Weekly" ? dbY * 100 + dbW : dbTfEff == "Monthly" ? dbY * 100 + dbMo : dbY * 10000 + dbMo * 100 + dbD

var float pHigh = na
var float pLow  = na
var float pOpen = na
var box[]   dBox  = array.new<box>()
var line[]  dVL   = array.new<line>()

if dboxOn and barstate.isconfirmed
    startNew = na(pHigh) or dbId != dbId[1]
    if startNew
        // finalise previous period implicitly (its objects keep their last extent)
        pHigh := high
        pLow  := low
        pOpen := open
        if dbBox
            b = box.new(bar_index, high, bar_index, low, xloc = xloc.bar_index,
                 border_color = dbLineCol, border_width = 1, bgcolor = dbFillBull)
            array.push(dBox, b)
            if array.size(dBox) > dbMax
                box.delete(array.shift(dBox))
        if dbVL
            v = line.new(bar_index, low, bar_index, high, xloc = xloc.bar_index,
                 extend = extend.both, color = dbLineCol, width = 1, style = line.style_dotted)
            array.push(dVL, v)
            if array.size(dVL) > dbMax
                line.delete(array.shift(dVL))
    else
        pHigh := math.max(pHigh, high)
        pLow  := math.min(pLow,  low)

    // extend / refresh the CURRENT period's objects
    pBull = close >= pOpen
    if dbBox and array.size(dBox) > 0
        cb = array.get(dBox, array.size(dBox) - 1)
        box.set_top(cb, pHigh)
        box.set_bottom(cb, pLow)
        box.set_right(cb, bar_index)
        box.set_bgcolor(cb, pBull ? dbFillBull : dbFillBear)

// ============================================================================
//  MODULE 5 · NEWS DANGER ZONES  (manual red-folder calendar, auto-filtered)
//  IMPORTANT: Pine Script CANNOT read an economic calendar — there is no API for
//  red-folder news inside TradingView. So you PASTE one master list of high-impact
//  events (a ~1-min weekly copy from ForexFactory). Each event carries its CURRENCY
//  code, and "Only this chart's currencies" auto-shows just the events that affect
//  the symbol you're on — so you keep ONE list for all charts.
//  Each shown event fills a red "NO TRADE ZONE" box over the N hours BEFORE it
//  (default 5h) + a vertical line at the event — so you don't enter before red news.
//  Format:  YYYY-MM-DD HH:MM CUR note ,  comma-separated.  Time may be 24h or am/pm.
//    e.g.  2026-06-22 18:00 CAD CPI, 2026-06-25 6:00pm USD PCE
// ============================================================================
var G5 = "5 · News Danger Zones"
newsOn   = input.bool(true, "Enable news danger zones", group = G5,
     tooltip = "Single master switch. Pine cannot auto-read news — paste the red-folder times below.")
newsList = input.string("2026-06-22 18:00 CAD CPI, 2026-06-24 07:00 AUD CPI, 2026-06-25 07:00 AUD Employment, 2026-06-25 18:00 USD PCE", "Red-folder news", group = G5,
     tooltip = "Format per event: YYYY-MM-DD HH:MM CUR note  (comma-separated). Time can be 24h (18:00) or am/pm (6:00pm). Include the 3-letter CURRENCY so auto-filter works. Paste ONLY high-impact (red) events from ForexFactory; update weekly.")
newsAuto = input.bool(true, "Only this chart's currencies", group = G5,
     tooltip = "ON = show only events whose currency matches the chart's pair (e.g. EURUSD shows EUR + USD). Lets you keep ONE master list for every chart. OFF = show all events.")
newsTz   = input.string("Asia/Kolkata", "News timezone", group = G5,
     tooltip = "Timezone the times above are in — MUST match your ForexFactory calendar setting. Default IST.")
newsBefore = input.float(5, "Hours before (danger window)", minval = 0, step = 0.5, group = G5,
     tooltip = "No-trade window length BEFORE each event. Your rule = 5h.")
newsAfter  = input.float(1, "Hours after", minval = 0, step = 0.5, group = G5,
     tooltip = "Optional extra window AFTER the event (post-news spike). 0 = none.")
newsCol    = input.color(color.red, "Restricted color", group = G5)
newsTransp = input.int(80, "Zone transparency", minval = 0, maxval = 100, group = G5,
     tooltip = "Fill opacity of the no-trade box. Lower = deeper/stronger color, higher = lighter. 80 = light-deep.")

// --- parse the pasted list ONCE into timestamps + currency + note ---
f_parseNews(lst, tz) =>
    ts  = array.new<int>()
    cur = array.new<string>()
    nt  = array.new<string>()
    if str.length(lst) > 0
        items = str.split(lst, ",")
        for i = 0 to array.size(items) - 1
            toks = str.split(array.get(items, i), " ")
            string dp = na
            string tp = na
            string cc = na
            string note = ""
            for j = 0 to array.size(toks) - 1
                tk = array.get(toks, j)
                if str.length(tk) > 0
                    if na(dp) and str.contains(tk, "-")
                        dp := tk
                    else if na(tp) and str.contains(tk, ":")
                        tp := tk
                    else if na(cc)
                        cc := tk
                    else
                        note := note + (str.length(note) > 0 ? " " : "") + tk
            if not na(dp) and not na(tp)
                ds   = str.split(dp, "-")
                lowt = str.lower(tp)
                isPM = str.contains(lowt, "pm")
                isAM = str.contains(lowt, "am")
                tms  = str.split(str.replace_all(str.replace_all(lowt, "pm", ""), "am", ""), ":")
                if array.size(ds) >= 3 and array.size(tms) >= 1
                    y  = int(str.tonumber(array.get(ds, 0)))
                    mo = int(str.tonumber(array.get(ds, 1)))
                    d  = int(str.tonumber(array.get(ds, 2)))
                    h  = int(str.tonumber(array.get(tms, 0)))
                    mi = array.size(tms) >= 2 ? int(str.tonumber(array.get(tms, 1))) : 0
                    if not na(h) and isPM and h < 12
                        h := h + 12
                    if not na(h) and isAM and h == 12
                        h := 0
                    if not na(y) and not na(mo) and not na(d) and not na(h) and not na(mi)
                        array.push(ts, timestamp(tz, y, mo, d, h, mi, 0))
                        array.push(cur, na(cc) ? "" : str.upper(cc))
                        array.push(nt, note)
    [ts, cur, nt]

var int[]    newsTs  = array.new<int>()
var string[] newsCur = array.new<string>()
var string[] newsNt  = array.new<string>()
if barstate.isfirst
    [pTs, pCu, pNt] = f_parseNews(newsList, newsTz)
    newsTs  := pTs
    newsCur := pCu
    newsNt  := pNt

// currencies of the current chart (e.g. EURUSD -> EUR + USD; XAUUSD -> XAU + USD).
// Robust match: quote ccy, base ccy, OR the code appearing in the ticker text.
ccyA    = str.upper(syminfo.currency)
ccyB    = str.upper(syminfo.basecurrency)
chartUp = str.upper(syminfo.ticker)
f_relevant(cc) => not newsAuto or str.length(cc) == 0 or cc == ccyA or cc == ccyB or str.contains(chartUp, cc)

// --- detect if the live bar sits inside a restricted window (for the alert) ---
beforeMs = newsBefore * 3600000.0
afterMs  = newsAfter  * 3600000.0
inZone = false
if newsOn and array.size(newsTs) > 0
    for i = 0 to array.size(newsTs) - 1
        if f_relevant(array.get(newsCur, i))
            ev = array.get(newsTs, i)
            if time >= ev - beforeMs and time <= ev + afterMs
                inZone := true
                break

// Tall fill range taken from recent data so the box looks full-height WITHOUT
// blowing up the price scale.
zoneHi = ta.highest(high, 500)
zoneLo = ta.lowest(low, 500)

// --- filled RESTRICTED AREA box (5h before -> event) + event line + label ----
var box[]   nBx = array.new<box>()
var line[]  nLn = array.new<line>()
var label[] nLb = array.new<label>()
if barstate.islast
    if array.size(nBx) > 0
        for i = 0 to array.size(nBx) - 1
            box.delete(array.get(nBx, i))
        array.clear(nBx)
    if array.size(nLn) > 0
        for i = 0 to array.size(nLn) - 1
            line.delete(array.get(nLn, i))
        array.clear(nLn)
    if array.size(nLb) > 0
        for i = 0 to array.size(nLb) - 1
            label.delete(array.get(nLb, i))
        array.clear(nLb)
    if newsOn and array.size(newsTs) > 0
        for i = 0 to array.size(newsTs) - 1
            cc = array.get(newsCur, i)
            ev = array.get(newsTs, i)
            // only draw events whose window hasn't already fully passed (hide old news)
            if f_relevant(cc) and ev + afterMs >= timenow
                startT = int(ev - beforeMs)
                rightT = int(ev + afterMs)
                // filled vertical no-trade zone from N hours before up to the event
                array.push(nBx, box.new(startT, zoneHi, rightT, zoneLo, xloc = xloc.bar_time,
                     border_color = color.new(newsCol, 60), bgcolor = color.new(newsCol, newsTransp)))
                // vertical line at the event time
                array.push(nLn, line.new(ev, zoneLo, ev, zoneHi, xloc = xloc.bar_time, extend = extend.both, color = newsCol, width = 2))
                nt  = array.get(newsNt, i)
                txt = "⛔ NO TRADE ZONE" + (str.length(cc) > 0 ? " · " + cc : "") + (str.length(nt) > 0 ? "\n" + nt : "")
                array.push(nLb, label.new(ev, zoneHi, txt, xloc = xloc.bar_time,
                     style = label.style_label_down, color = newsCol, textcolor = color.white, size = tSize))

alertcondition(inZone, "In no-trade news window", "Inside a red-folder no-trade window — do not take entries")

// ============================================================================
//  MODULE 6 · MULTI-TIMEFRAME TREND  (top-right dashboard)
//  Trend on 15m / 1H / 2H / 4H / Daily + an overall weighted probability.
//  Per-TF rule: BULL only if price is above a RISING trend-EMA, BEAR if below a
//  FALLING one, else NEUTRAL (transition). Higher timeframes weigh more in the
//  overall read, so the % tells you how aligned the big picture is.
// ============================================================================
var G6 = "6 · MTF Trend"
trendOn  = input.bool(true, "Enable MTF trend dashboard", group = G6, tooltip = "Single master switch.")
trendLen = input.int(50, "Trend EMA length", minval = 5, group = G6,
     tooltip = "EMA used to judge each timeframe's trend. BEST 50. 20 = faster, 200 = only major trends.")
trendPos = input.string("Top Right", "Table position", options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group = G6)
cTBull = input.color(#26a69a, "Bull", inline = "t1", group = G6)
cTBear = input.color(#ef5350, "Bear", inline = "t1", group = G6)
cTNeut = input.color(color.gray, "Neutral", inline = "t1", group = G6)

sym = syminfo.tickerid
f_tfTrend(tf, ln) =>
    [c, e, ep] = request.security(sym, tf, [close, ta.ema(close, ln), ta.ema(close, ln)[1]],
         lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)
    rising = e > ep
    c > e and rising ? 1 : c < e and not rising ? -1 : 0

t15 = f_tfTrend("15",  trendLen)
t1h = f_tfTrend("60",  trendLen)
t2h = f_tfTrend("120", trendLen)
t4h = f_tfTrend("240", trendLen)
tD  = f_tfTrend("D",   trendLen)

// weighted overall (Daily weighs most)
bullW = (t15 > 0 ? 1 : 0) + (t1h > 0 ? 2 : 0) + (t2h > 0 ? 3 : 0) + (t4h > 0 ? 4 : 0) + (tD > 0 ? 5 : 0)
bearW = (t15 < 0 ? 1 : 0) + (t1h < 0 ? 2 : 0) + (t2h < 0 ? 3 : 0) + (t4h < 0 ? 4 : 0) + (tD < 0 ? 5 : 0)
netW  = bullW - bearW
ovDir = netW > 0 ? 1 : netW < 0 ? -1 : 0
ovPct = math.round(math.abs(netW) / 15.0 * 100)

f_tt(d) => d > 0 ? "Bullish" : d < 0 ? "Bearish" : "Neutral"
f_tc(d) => d > 0 ? cTBull : d < 0 ? cTBear : cTNeut
f_tpos(p) => p == "Top Left" ? position.top_left : p == "Bottom Right" ? position.bottom_right : p == "Bottom Left" ? position.bottom_left : position.top_right

var table mtfTbl = table.new(f_tpos(trendPos), 2, 7, border_width = 1, frame_color = color.new(color.gray, 40), frame_width = 1)
f_trow(r, k, v, c) =>
    table.cell(mtfTbl, 0, r, k, text_color = color.silver, text_size = tSize, text_halign = text.align_left, bgcolor = color.new(color.black, 10))
    table.cell(mtfTbl, 1, r, v, text_color = c, text_size = tSize, text_halign = text.align_left, bgcolor = color.new(color.black, 10))
if barstate.islast and trendOn
    f_trow(0, "MTF TREND", syminfo.ticker, color.aqua)
    f_trow(1, "15m",   f_tt(t15), f_tc(t15))
    f_trow(2, "1H",    f_tt(t1h), f_tc(t1h))
    f_trow(3, "2H",    f_tt(t2h), f_tc(t2h))
    f_trow(4, "4H",    f_tt(t4h), f_tc(t4h))
    f_trow(5, "Daily", f_tt(tD),  f_tc(tD))
    f_trow(6, "Overall", f_tt(ovDir) + "  " + str.tostring(ovPct) + "%", f_tc(ovDir))

// (Projection module removed)
